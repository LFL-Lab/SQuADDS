# SQuADDS MCP Server Configuration
# Copy this file to .env and fill in your values.

# HuggingFace token for accessing SQuADDS datasets
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# MCP transport: "stdio" (for local AI assistants) or "streamable-http" (for networked usage)
SQUADDS_MCP_TRANSPORT=stdio

# HTTP transport settings (only used when SQUADDS_MCP_TRANSPORT=streamable-http)
SQUADDS_MCP_HOST=0.0.0.0
SQUADDS_MCP_PORT=8000
